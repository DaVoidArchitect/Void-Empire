# SovereignKnowledgeNode Schema Definition
# ============================================================================

intent SovereignKnowledgeNode {
    steward: "truth_core";
    target: "knowledge_matrix";
    license: "PRIVATE";
    scope: "Global";
    provenance: "truth_authority";
    lifetime: 365 days;
}

