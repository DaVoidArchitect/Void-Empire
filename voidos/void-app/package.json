{
  "name": "void-alpha-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "check": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "server:build": "vite build --ssr server/index.ts --outDir server-dist",
    "server:start": "node server-dist/index.js",
    "vps:build": "npm run build && npm run server:build",
    "vps:start": "node server-dist/index.js",
    "local": "npm run build && python -m http.server 8090 -d dist"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^6.0.3",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.4",
    "@netlify/functions": "^5.2.0",
    "@netlify/identity": "^1.1.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
