# ============================================================
#  VOID EMPIRE — Truth AI Cognitive Terminal
#  truth_terminal.logos
#
#  The sovereign AI companion terminal. An OpenAI-style
#  conversational interface rendered through thermodynamic
#  constraint and dark-aesthetic intent architecture.
#
#  Cognitive Architecture:
#    TerminalIdle ──▶ ProcessingQuery ──▶ ResponseRendering
#         │                │                     │
#         ├─▶ DiagnoseMode ┘                     │
#         ├─▶ OptimizeMode ─────────────────────▶│
#         ├─▶ MarketReportMode ─────────────────▶│
#         │                                      │
#         ◀──────────────────────────────────────┘
#
#  Truth does not hallucinate. Truth reasons under budget.
#  Every inference consumes energy. Every token has mass.
# ============================================================

# import "voidmesh/core.logos";

# ──────────────────────────────────────────────────────────
#  Intent: TruthTerminal
#
#  Models the full lifecycle of a single AI terminal session.
#  The terminal accepts natural-language queries and slash
#  commands (/diagnose, /optimize, /market_report), routes
#  them through bounded cognitive pipelines, and streams
#  responses back with a typewriter animation.
#
#  Energy is the hard constraint. When the 300 Wh session
#  budget is exhausted, the terminal enters EnergyDepleted
#  and refuses further inference until replenished.
# ──────────────────────────────────────────────────────────

intent TruthTerminal {
    steward:     truth_coordinator;
    target:      cognitive_substrate;
    license:     PRIVATE;
    scope:       Individual;
    provenance:  truth_authority;
    lifetime:    24h;

    # ── Global thermodynamic envelope ──────────────────────
    # 300 Wh covers ~250 deep queries or ~1500 fast queries
    # per session. Mass accounts for transient neural state
    # materialized across wafer cores during inference.
    require {
        energy 300.0 Wh;
        mass 1.0 kg;
    }

    # ══════════════════════════════════════════════════════
    #  State: TerminalIdle
    #
    #  The blinking cursor. A typewriter prompt awaits input.
    #  No computation burns here — only the faintest idle
    #  draw of the display substrate. From this nexus the
    #  user may submit free-form queries or invoke slash
    #  commands to enter specialized cognitive modes.
    # ══════════════════════════════════════════════════════

    state TerminalIdle {
        # Free-form natural language query
        on submit_query -> ProcessingQuery {
            require energy 0.5 Wh;
            require cycle 50 cycles;
        }

        # /diagnose — wafer thermal & core failure analysis
        on diagnose_command -> DiagnoseMode {
            require energy 1.0 Wh;
            require cycle 100 cycles;
        }

        # /optimize — auto-tune core frequencies
        on optimize_command -> OptimizeMode {
            require energy 2.0 Wh;
            require cycle 150 cycles;
        }

        # /market_report — GTN price & trade intelligence
        on market_report_command -> MarketReportMode {
            require energy 1.5 Wh;
            require cycle 120 cycles;
        }

        # Graceful session termination
        on exit -> return;
    }

    # ══════════════════════════════════════════════════════
    #  State: ProcessingQuery
    #
    #  [THINKING] — the reasoning trace is visible.
    #  Truth exposes its chain-of-thought: node activations,
    #  attention adjustments, confidence recalibrations.
    #  Two inference paths diverge here:
    #    • fast_response — single-pass, low-energy (1.2 Wh)
    #    • deep_response — multi-pass with self-critique,
    #      verification, and citation cross-ref (5.0 Wh)
    #
    #  If the session energy envelope is exhausted mid-
    #  inference, the terminal gracefully degrades into
    #  EnergyDepleted rather than producing partial output.
    # ══════════════════════════════════════════════════════

    state ProcessingQuery {
        # Single-pass inference — fast, efficient
        on generate_fast_response -> ResponseRendering {
            require energy 1.2 Wh;
            require cycle 120 cycles;
        }

        # Multi-pass deep reasoning with self-verification
        on generate_deep_response -> ResponseRendering {
            require energy 5.0 Wh;
            require cycle 500 cycles;
        }

        # Energy budget exhausted — cannot complete inference
        on out_of_energy -> EnergyDepleted {
            require energy 0.01 Wh;
        }
    }

    # ══════════════════════════════════════════════════════
    #  State: DiagnoseMode
    #
    #  /diagnose — Analyze wafer thermals, identify failing
    #  cores, map hot-spots across the computational mesh.
    #  Reads sensor telemetry from the cognitive substrate
    #  and produces a structured diagnostic report.
    #
    #  Cost: 2.0 Wh for full thermal scan + core health
    #  matrix generation across all active wafer tiles.
    # ══════════════════════════════════════════════════════

    state DiagnoseMode {
        on diagnosis_complete -> ResponseRendering {
            require energy 2.0 Wh;
            require cycle 200 cycles;
        }

        # Sensor read failure or incomplete telemetry
        on diagnosis_error -> TerminalIdle {
            require energy 0.1 Wh;
        }
    }

    # ══════════════════════════════════════════════════════
    #  State: OptimizeMode
    #
    #  /optimize — Auto-tune core frequencies for maximum
    #  efficiency. Runs a gradient-free search over the
    #  frequency-voltage curve of each active core tile,
    #  seeking the Pareto front of performance vs. thermal
    #  dissipation. Most energy-expensive command mode.
    #
    #  Cost: 3.0 Wh — the optimization loop itself is
    #  computationally intensive, but the gains compound
    #  across all subsequent queries in the session.
    # ══════════════════════════════════════════════════════

    state OptimizeMode {
        on optimization_complete -> ResponseRendering {
            require energy 3.0 Wh;
            require cycle 300 cycles;
        }

        # Frequency lock failure or thermal runaway abort
        on optimization_error -> TerminalIdle {
            require energy 0.1 Wh;
        }
    }

    # ══════════════════════════════════════════════════════
    #  State: MarketReportMode
    #
    #  /market_report — GTN (Graviton Token Network) price
    #  analysis and trade recommendations. Aggregates order
    #  book depth, historical volatility, and sentiment
    #  signals from the mesh network to produce actionable
    #  intelligence for the sovereign operator.
    #
    #  Cost: 2.5 Wh — includes real-time data ingestion
    #  and multi-factor model evaluation.
    # ══════════════════════════════════════════════════════

    state MarketReportMode {
        on report_complete -> ResponseRendering {
            require energy 2.5 Wh;
            require cycle 250 cycles;
        }

        # Data feed timeout or model convergence failure
        on report_error -> TerminalIdle {
            require energy 0.1 Wh;
        }
    }

    # ══════════════════════════════════════════════════════
    #  State: ResponseRendering
    #
    #  Stream response text with a typewriter animation.
    #  Each glyph materializes on the dark terminal canvas
    #  with a deliberate cadence — Truth does not rush.
    #  The user may interrupt mid-stream to abort verbose
    #  output and return to the idle prompt.
    #
    #  Cost: 0.05 Wh — rendering is cheap; the cognitive
    #  work was already paid for upstream.
    # ══════════════════════════════════════════════════════

    state ResponseRendering {
        # Full response streamed successfully
        on render_complete -> TerminalIdle {
            require energy 0.05 Wh;
            require cycle 5 cycles;
        }

        # User interrupted the output stream (Ctrl+C / tap)
        on user_interrupt -> TerminalIdle {
            require energy 0.02 Wh;
        }
    }

    # ══════════════════════════════════════════════════════
    #  State: EnergyDepleted
    #
    #  The terminal has exhausted its thermodynamic budget.
    #  No further inference is possible until the energy
    #  envelope is replenished — either by session reset,
    #  external charge, or GTN energy-token redemption.
    #
    #  This is not an error. This is physics.
    # ══════════════════════════════════════════════════════

    state EnergyDepleted {
        # Energy replenished — return to idle prompt
        on replenish_energy -> TerminalIdle {
            require energy 0.01 Wh;
        }
    }
}

# ============================================================
#  End of truth_terminal.logos
#
#  "Every token has a cost. Every inference, a consequence.
#   Truth operates within the laws of thermodynamics —
#   not above them."
#                              — VOID Cognitive Doctrine
# ============================================================
